{
  "$schema": "~/.claude/hooks/tool-permissions/permissions.schema.json",
  "version": 1,
  "allow": {
    "WebFetch": [
      "^https://([a-zA-Z0-9-]+\\.)*ncbi\\.nlm\\.nih\\.gov(/|$)",
      "^https://www.ebi.ac.uk(/|$)",
      "^https://scholar.google.com(/|$)",
      "^https://doaj.org(/|$)",
      "^https://opensciencedirectory.net(/|$)",
      "^http://www.freemedicaljournals.com(/|$)",
      "^https://openmd.com(/|$)",
      "^https://www.tripdatabase.com(/|$)",
      "^https://doi.org(/|$)",
      "^https://www.mdpi.com(/|$)",
      "^https://link.springer.com(/|$)",
      "^https://www.sciencedirect.com(/|$)",
      "^https://www.cambridge.org(/|$)",
      "^https://www.tandfonline.com(/|$)",
      "^https://dro.deakin.edu.au(/|$)",
      "^https://www.sci-hub.st(/|$)",
      "^https://europepmc.org(/|$)",
      "^https://aura.abdn.ac.uk(/|$)"
    ],
    "Bash": [
      "^curl -s [\"']https://([a-zA-Z0-9-]+\\.)*ncbi\\.nlm\\.nih\\.gov/",
      "^curl -s [\"']https://www.ebi.ac.uk/",
      "^curl -s [\"']https://scholar.google.com/",
      "^curl -s [\"']https://doaj.org/",
      "^curl -s [\"']https://opensciencedirectory.net/",
      "^curl -s [\"']http://www.freemedicaljournals.com/",
      "^curl -s [\"']https://openmd.com/",
      "^curl -s [\"']https://www.tripdatabase.com/",
      "^curl -s [\"']https://doi.org/",
      "^curl -s [\"']https://www.mdpi.com/",
      "^curl -s [\"']https://link.springer.com/",
      "^curl -s [\"']https://www.sciencedirect.com/",
      "^curl -s [\"']https://www.cambridge.org/",
      "^curl -s [\"']https://www.tandfonline.com/",
      "^curl -s [\"']https://dro.deakin.edu.au/",
      "^curl -s [\"']https://www.sci-hub.st/",
      "^curl -s [\"']https://europepmc.org/",
      "^curl -s [\"']https://aura.abdn.ac.uk/",
      "^uv run med-db(\\s|$)",
      "^uv run med-db-validate(\\s|$)",
      "^uv run med-db-lookup(\\s|$)",
      "^uv run med-db-query(\\s|$)",
      "^uv run med-db-lookup-icd11(\\s|$)",
      "^uv run med-db-lookup-dsm5(\\s|$)",
      "^uv run med-db-download-icd11(\\s|$)",
      "^uv run med-db-setup-dsm5(\\s|$)",
      "^uv run lint-md(\\s|$)",
      "^uv run test(\\s|$)",
      "^python3? -m json.tool(\\s|$)",
      "^html2text(\\s|$)"
    ]
  }
}
